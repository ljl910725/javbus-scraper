# JavBus 镜像站地址
BASE_URL=https://www.javbus.com

# HTTP/HTTPS 代理（可选，部分地区访问需要）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 年龄验证 Cookie（可选，遇到跳转时手动从浏览器复制）
# JAVBUS_COOKIE=age=verified; ...

# 封面下载目录（相对项目根目录）
COVER_DIR=downloads/covers

# 字幕保存可浏览的根目录（逗号分隔，容器内路径或相对项目根目录）
SUBTITLE_BROWSE_ROOTS=downloads

# 批量请求间隔（秒）
REQUEST_DELAY=0.8

# 请求超时（秒）
REQUEST_TIMEOUT=30

# 115 网盘 Cookie（从浏览器登录 115.com 后复制，需包含 UID、CID、SEID 等）
# P115_COOKIE=UID=123456_A1_1234567890; CID=...; SEID=...; ...

# JWT 密钥（生产环境请修改）
JWT_SECRET=change-me-in-production

# 翻译默认配置
TRANSLATE_ENGINE=free
TRANSLATE_TARGET_LANG=zh-CN
AI_TRANSLATE_BASE_URL=https://api.openai.com/v1
# AI_TRANSLATE_API_KEY=sk-...
AI_TRANSLATE_MODEL=gpt-4o-mini

# CloudDrive2 配置
CD2_HOST=localhost:19798
# 认证方式：password（用户名密码）或 token（API 令牌）
CD2_AUTH_MODE=password
CD2_USERNAME=admin
CD2_PASSWORD=your_password
# CD2_TOKEN=your_api_token
# CD2_OFFLINE_FOLDER=/115open/云下载

# 推送方式：cd2 或 p115（默认 cd2）
PUSH_BACKEND=cd2
